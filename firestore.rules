rules_version = '2';

// fto.twistytools.com — Firestore security rules (the REAL authorization
// boundary). DORMANT until M6: js/config.js has firebase:null (demo mode) and
// no Firebase project exists for this site yet. Versioned here so M6 starts
// from a reviewed baseline. Deploy (once a project exists) with:
//
//   firebase deploy --only firestore:rules
//
// The census collections the Skewb parent had (solutions, meta, moderators,
// moderatorInvites, admins) were deleted at M0 with the census itself; git
// history retains them if M6 ever needs the patterns back.
service cloud.firestore {
  match /databases/{database}/documents {

    // per-user data: solver prefs + trainer progress (own doc only)
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
